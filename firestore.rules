rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 輔助函式 ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'taidu.patisserie.2025@gmail.com';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── 1. 員工資料 ──
    match /employees/{employeeId} {
      allow read: if isOwner(employeeId) || isAdmin();
      allow write: if isAdmin();
    }

    // ── 2. 出勤打卡紀錄 ──
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── 3. 排班表 ──
    match /schedules/{scheduleId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── 4. 薪資單 ──
    match /payroll/{payrollId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── 5. 系統設定 ──
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 6. 請假申請 ──
    match /leaves/{leaveId} {
      // 管理員可讀全部；員工只能讀自己的
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      // 員工只能新增屬於自己的假單
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      // 員工只能撤銷（更新 status）自己且狀態為 pending 的假單；管理員可修改所有
      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.employeeId == request.auth.uid &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // ── 7. 加班申請 ──
    match /overtime_requests/{otId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.employeeId == request.auth.uid &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // ── 8. 補卡申請 ──
    match /punch_corrections/{pcId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── 9. 打卡異常申訴 ──
    match /attendance_appeals/{apId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
